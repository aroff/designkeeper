{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://designkeeper.dev/schemas/structural/output.schema.json",
  "title": "StructuralReviewOutput",
  "description": "Structured agent output for dk structural review. Grades nine sub-dimensions across three groups: Structure, Complexity, Expressiveness.",
  "type": "object",
  "required": [
    "summary",
    "grades",
    "overall_score",
    "good_things",
    "findings",
    "limitations",
    "suggested_next_steps"
  ],
  "additionalProperties": false,
  "properties": {
    "summary": {
      "type": "object",
      "required": ["verdict", "overall_score", "structure_score", "complexity_score", "expressiveness_score", "one_paragraph"],
      "additionalProperties": false,
      "properties": {
        "verdict": {
          "type": "string",
          "enum": ["approve", "approve_with_comments", "request_changes", "reject"],
          "description": "reject: overall<4 or any critical. request_changes: overall 4-5 or any high. approve_with_comments: overall 6-7. approve: overall>=8."
        },
        "overall_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 10,
          "description": "Mean of nine sub-dimensions with critical penalty applied (−0.5 per sub-dimension scored <4, floor 0)."
        },
        "structure_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 10,
          "description": "Unpenalized mean of file_decomposition, layer_integrity, helper_reuse."
        },
        "complexity_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 10,
          "description": "Unpenalized mean of structural_simplicity, branching_complexity, orchestration_quality."
        },
        "expressiveness_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 10,
          "description": "Unpenalized mean of abstraction_quality, type_contract_clarity, legibility."
        },
        "one_paragraph": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000,
          "description": "Summary of structural health, group highlights, and any critical penalty applied."
        }
      }
    },
    "grades": {
      "type": "object",
      "description": "Per-dimension scores 0-10 with rationale. All nine structural sub-dimensions.",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/grade_entry"
      },
      "propertyNames": {
        "$ref": "#/$defs/dimension"
      }
    },
    "overall_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 10,
      "description": "Must match summary.overall_score (post-penalty rounded mean)."
    },
    "good_things": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "description": "Structural choices that genuinely improve maintainability and are worth retaining."
    },
    "findings": {
      "type": "array",
      "maxItems": 50,
      "items": { "$ref": "#/$defs/finding" }
    },
    "limitations": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "description": "What could not be verified (generated code skipped, partial diff, no architectural docs, etc.)."
    },
    "suggested_next_steps": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "description": "Ordered actions for the author, critical findings first."
    }
  },
  "$defs": {
    "dimension": {
      "type": "string",
      "enum": [
        "file_decomposition",
        "layer_integrity",
        "helper_reuse",
        "structural_simplicity",
        "branching_complexity",
        "orchestration_quality",
        "abstraction_quality",
        "type_contract_clarity",
        "legibility"
      ]
    },
    "grade_entry": {
      "oneOf": [
        {
          "type": "object",
          "required": ["score", "rationale"],
          "additionalProperties": false,
          "properties": {
            "score": {
              "type": "number",
              "minimum": 0,
              "maximum": 10
            },
            "rationale": {
              "type": "string",
              "minLength": 1,
              "maxLength": 500
            }
          }
        },
        {
          "type": "object",
          "required": ["not_evaluated", "rationale"],
          "additionalProperties": false,
          "properties": {
            "not_evaluated": { "type": "boolean", "const": true },
            "rationale": {
              "type": "string",
              "minLength": 1,
              "maxLength": 500
            }
          }
        }
      ]
    },
    "finding": {
      "type": "object",
      "required": [
        "id",
        "dimension",
        "severity",
        "location",
        "observation",
        "why_it_matters",
        "recommended_action"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$",
          "description": "Stable slug, e.g. layer-integrity-001."
        },
        "dimension": { "$ref": "#/$defs/dimension" },
        "severity": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low"],
          "description": "critical: score 0-3 (blocks merge, quality penalty). high: score 4-5 (request changes). medium: score 6-7 (approve with comments). low: score 8 (nit-level)."
        },
        "location": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200,
          "description": "path/to/file.ext:42-48, module name, or change_scope (whole diff)."
        },
        "observation": {
          "type": "string",
          "minLength": 10,
          "maxLength": 1000
        },
        "why_it_matters": {
          "type": "string",
          "minLength": 10,
          "maxLength": 500
        },
        "recommended_action": {
          "type": "string",
          "minLength": 10,
          "maxLength": 1000
        },
        "evidence": {
          "type": "string",
          "maxLength": 500,
          "description": "Optional short excerpt or symbol reference supporting the observation."
        },
        "suggested_patch": {
          "type": "string",
          "maxLength": 2000,
          "description": "Optional unified diff or code snippet showing the fix."
        }
      }
    }
  }
}
